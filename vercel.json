{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://dineingo-backend.onrender.com/api/v1/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://dineingo-backend.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api/v1|uploads|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}

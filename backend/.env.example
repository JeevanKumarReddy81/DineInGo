# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dineingo?retryWrites=true&w=majority

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (for authentication tokens)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Admin Configuration
ADMIN_CODE=492731

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase Admin SDK (optional, for server-side Firebase operations)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Google Wallet API (for wallet pass generation)
GOOGLE_WALLET_ISSUER_ID=your_issuer_id
GOOGLE_WALLET_CLASS_ID=your_class_id

# Apple Wallet (for wallet pass generation)
APPLE_PASS_TYPE_ID=pass.com.dineingo.booking
APPLE_TEAM_ID=your_team_id

# AI Chatbot Configuration
OPENROUTER_API_KEY=your_openrouter_api_key
AI_MODEL=google/gemma-3n-e4b-it:free

# ============================================
# SECURITY: Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/dineingoapp

# ============================================
# SECURITY SECRETS (REQUIRED)
# Generate strong random values for these
# Minimum 32 characters recommended
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
SESSION_SECRET=your-super-secret-session-key-min-32-characters-long
ADMIN_CODE=your-admin-code-min-6-digits

# ============================================
# FIREBASE CONFIGURATION
# ============================================
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ============================================
# AI SERVICES (OPTIONAL)
# ============================================
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_MODEL=sarvam-m
OPENROUTER_API_KEY=your-openrouter-api-key
AI_MODEL=google/gemma-2-9b-it:free

# ============================================
# PAYMENT PROCESSING (OPTIONAL)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ============================================
# EMAIL SERVICE (OPTIONAL)
# ============================================
EMAIL_SERVICE_API_KEY=your-email-service-api-key
EMAIL_FROM=noreply@dineingoapp.com

# ============================================
# REDIS CONFIGURATION (FOR RATE LIMITING)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# ============================================
# FRONTEND URLS (FOR CORS)
# ============================================
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:3000

# ============================================
# RATE LIMITING (OPTIONAL - uses defaults if not set)
# ============================================
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX_REQUESTS=100
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX_REQUESTS=5

# ============================================
# SECURITY FEATURES (OPTIONAL)
# ============================================
# ENABLE_2FA=true
# ENABLE_EMAIL_VERIFICATION=true
# ENABLE_AUDIT_LOGGING=true
# ENABLE_ANOMALY_DETECTION=true

# ============================================
# IMPORTANT SECURITY NOTES
# ============================================
# 1. NEVER commit this file to version control
# 2. Use strong, random values for all secrets
# 3. Rotate secrets regularly (every 90 days)
# 4. Use different values for each environment
# 5. Store securely (use secret management service in production)
# 6. Audit access to these variables
# 7. Never share secrets via email or chat
# 8. Use environment-specific .env files

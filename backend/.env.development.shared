# Shared Development Environment Variables
# This file contains NON-SENSITIVE development credentials
# Safe to commit for team collaboration
# DO NOT use production credentials here!

# MongoDB - Development Database (Shared)
# Note: This should be a separate development database, NOT production
MONGODB_URI=mongodb+srv://dev-user:dev-password@dev-cluster.mongodb.net/dineingo-dev?retryWrites=true&w=majority

# Email - Development (Optional - each dev can use their own)
# For testing, you can use a test email service like Mailtrap
EMAIL_USER=dev@dineingo.com
EMAIL_PASS=dev-app-password

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Secret - Development Only (NOT for production)
JWT_SECRET=dev-jwt-secret-change-in-production-12345

# Admin Code - Development Only
ADMIN_CODE=492731

# CORS Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Firebase Admin - Development Project
FIREBASE_PROJECT_ID=dineingo-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@dineingo-dev.iam.gserviceaccount.com
# Note: Private key should still be in local .env, not here

# Google Wallet - Development
GOOGLE_WALLET_ISSUER_ID=dev_issuer_id
GOOGLE_WALLET_CLASS_ID=dev_class_id

# Apple Wallet - Development
APPLE_PASS_TYPE_ID=pass.com.dineingo.booking.dev
APPLE_TEAM_ID=DEV_TEAM_ID

# AI Chatbot Configuration
# Note: Get your own API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=google/gemma-3n-e4b-it:free

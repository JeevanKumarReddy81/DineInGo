# ============================================
# RENDER BACKEND ENVIRONMENT VARIABLES
# Copy these into the "Advanced" section on Render.com
# ============================================

# --- Core App settings ---
PORT=8080
NODE_ENV=production
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dineingo
JWT_SECRET=dineingo_secure_jwt_2026_!!
SESSION_SECRET=dineingo_session_secret_2026_!!
ADMIN_CODE=123456

# --- Frontend Links (Update with your Vercel URL) ---
FRONTEND_URL=https://your-app.vercel.app
ADMIN_URL=https://your-app.vercel.app
CLIENT_URL=https://your-app.vercel.app

# --- Email Service (Gmail SMTP) ---
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# --- Email Service (Brevo Fallback) ---
BREVO_API_KEY=your_brevo_key
BREVO_SMTP_USER=your_brevo_email

# --- AI Chatbot (Sarvam/OpenRouter) ---
SARVAM_API_KEY=your_sarvam_key
SARVAM_MODEL=sarvam-m
OPENROUTER_API_KEY=your_openrouter_key
AI_MODEL=google/gemma-3n-e4b-it:free
PRIMARY_LLM_PROVIDER=sarvam

# --- Media (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
